# Hugging Face access token (needed for gated models and the Inference API)
# Get one free at: https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=your_hf_token_here

# Vector store location
VECTORSTORE_DIR=./data/vectorstore

# PDF source directory
PDF_DIR=./data/pdfs

# --- Model config ---
# Embedding model (runs locally via sentence-transformers, no API needed)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Reranker model (runs locally via sentence-transformers CrossEncoder)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# LLM mode: "api" uses the HF Inference API (fast, no GPU needed),
#           "local" downloads and runs the model on your own machine/GPU
LLM_MODE=api

# Used when LLM_MODE=api -> calls this model via Hugging Face Inference API
LLM_MODEL_API=mistralai/Mistral-7B-Instruct-v0.3

# Used when LLM_MODE=local -> loads this model locally with transformers
LLM_MODEL_LOCAL=microsoft/Phi-3-mini-4k-instruct
